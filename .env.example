# ============================================================================
# disease_warehouse — local environment overrides
# ----------------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and fill in your own values.
# The CLI auto-loads `.env` at the repo root on every `python -m disease_warehouse ...`
# invocation, so you don't have to export these variables in each shell.
# ============================================================================

# Required to enable LLM enrichment of LOW-confidence columns during scaffold.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
