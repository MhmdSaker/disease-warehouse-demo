# ============================================================================
# disease_warehouse — local environment overrides
# ----------------------------------------------------------------------------
# Copy this file to `.env` (which is git-ignored) and fill in your own values.
# The CLI auto-loads `.env` at the repo root on every `python -m disease_warehouse ...`
# invocation, so you don't have to export these variables in each shell.
# ============================================================================

# ── Cloud LLM (optional) ────────────────────────────────────────────────────
# Set this to enable Gemini fallback for LOW-confidence columns during
# scaffold. Get a key at https://aistudio.google.com/app/apikey.
# You can disable cloud calls entirely by passing `--privacy strict` to the
# scaffold command, regardless of whether this key is set.
GEMINI_API_KEY=

# ── Local SLM via ollama (optional) ─────────────────────────────────────────
# If ollama is installed (https://ollama.com), the scaffold command will use
# it automatically when `--slm auto` is in effect. Defaults match the ollama
# defaults; override only if you bind ollama to a non-standard host/port.
#
#   1. Install ollama and start the daemon
#   2. Pull a model that matches the preset you intend to use:
#        ollama pull phi3.5           # --slm small (default, 3.8B Q4, ~2.3 GB)
#        ollama pull qwen2.5:1.5b     # --slm tiny  (low-end CPU, ~1 GB)
#        ollama pull biomistral:7b    # --slm small-bio (biomedical 7B)
#        ollama pull qwen2.5:7b       # --slm mid
#        ollama pull meditron:7b      # --slm mid-bio (NEVER bare 'meditron' — that pulls 70B)
#   3. Run scaffold normally — auto-detection takes over.
#
# OLLAMA_HOST=127.0.0.1
# OLLAMA_PORT=11434
#
# Advanced: cap the ollama context window. Some models ship with a 128K
# context that makes ollama reserve a huge KV cache up-front (Phi-3.5-mini
# needs ~50 GB without this cap). 8192 is plenty for our batched prompts.
# DW_OLLAMA_NUM_CTX=8192
# DW_OLLAMA_NUM_PREDICT=6144
